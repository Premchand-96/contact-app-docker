pipeline {
    agent any

    environment {
        S3_BUCKET = 'contact-app-frontend-vicky'
        AWS_DEFAULT_REGION = 'eu-north-1'
    }

    stages {
        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/Premchand-96/contact-app-docker.git'
            }
        }

        stage('Deploy index.html to S3') {
            steps {
                sh '''
                cd ${WORKSPACE}

                # Upload ONLY index.html
                aws s3 cp frontend/index.html s3://$S3_BUCKET/index.html --region $AWS_DEFAULT_REGION
                '''
            }
        }
    }

    post {
        success {
            echo "index.html deployed successfully!"
            echo "Check: http://contact-app-frontend-vicky.s3-website-eu-north-1.amazonaws.com"
        }
        failure {
            echo "Deployment failed. Check logs."
        }
    }
}
